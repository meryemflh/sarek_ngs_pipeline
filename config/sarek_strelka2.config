// =============================================================================
// sarek_strelka2.config — Nextflow configuration for Sarek + Strelka2
// Author: Meryem Fellah | Sequentia Biotech 2025
//
// Used for: BWA-MEM + BQSR + Strelka2 on 7 GIAB samples (chr22)
// Sarek version: 3.5.1
// Nextflow version: 22.10.6
//
// Strelka2 uses a tiered haplotype model:
//   - Rapid evaluation for simple/common sites
//   - Micro-assembly triggered only when necessary
//   - Empirical Variant Scoring (EVS) for indels and complex variants
//     integrating depth, allele frequency, and strand bias
//
// In our benchmark: Strelka2 showed more balanced precision/recall than
// DeepVariant, positioning closer to the main manual-run cluster.
// =============================================================================

params {

    // ── Input / Output ────────────────────────────────────────────────────────
    input           = "/media/sequentia/sdb1/visitor3/sarek/samplesheets/samplesheet_giab_all.csv"
    outdir          = "/media/sequentia/sdb1/visitor3/process/sarek/strelka2"

    // ── Reference genome ─────────────────────────────────────────────────────
    genome          = null
    fasta           = "/media/sequentia/sdb1/visitor3/reference/Homo_sapiens.GRCh38.dna.toplevel.fa"
    fasta_fai       = "/media/sequentia/sdb1/visitor3/reference/Homo_sapiens.GRCh38.dna.toplevel.fa.fai"
    bwa             = "/media/sequentia/sdb1/visitor3/reference/bwa_index/"

    // ── Known variant sites for BQSR ─────────────────────────────────────────
    dbsnp            = "/media/sequentia/sdb1/visitor3/databases/dbsnp_152.hg38.vcf.gz"
    dbsnp_tbi        = "/media/sequentia/sdb1/visitor3/databases/dbsnp_152.hg38.vcf.gz.tbi"
    known_indels     = "/media/sequentia/sdb1/visitor3/databases/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    known_indels_tbi = "/media/sequentia/sdb1/visitor3/databases/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi"

    // ── Analysis scope ────────────────────────────────────────────────────────
    intervals       = "chr22"

    // ── Pipeline steps ────────────────────────────────────────────────────────
    // Reads are already trimmed — skip Sarek's internal trimming step
    trim_fastq      = false

    // ── Variant caller ────────────────────────────────────────────────────────
    tools           = "strelka"

    // ── Analysis type ─────────────────────────────────────────────────────────
    analysis_type   = "germline"

    // ── Compute ───────────────────────────────────────────────────────────────
    max_cpus        = 30
    max_memory      = "120.GB"
    max_time        = "72.h"
}

// ── Executor ─────────────────────────────────────────────────────────────────
process {
    executor = "local"

    withName: "STRELKA_GERMLINE" {
        cpus   = 30
        memory = "40.GB"
    }

    withName: "BWAMEM1_MEM" {
        cpus   = 30
        memory = "60.GB"
    }

    withName: "GATK4_MARKDUPLICATES" {
        cpus   = 8
        memory = "32.GB"
    }

    withName: "GATK4_BASERECALIBRATOR" {
        cpus   = 8
        memory = "16.GB"
    }
}

// ── Docker ────────────────────────────────────────────────────────────────────
docker {
    enabled    = true
    runOptions = "-u \$(id -u):\$(id -g)"
}
