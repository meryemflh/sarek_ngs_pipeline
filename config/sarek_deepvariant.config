// =============================================================================
// sarek_deepvariant.config — Nextflow configuration for Sarek + DeepVariant
// Author: Meryem Fellah | Sequentia Biotech 2025
//
// Used for: BWA-MEM + BQSR + DeepVariant on 7 GIAB samples (chr22)
// Sarek version: 3.5.1
// Nextflow version: 22.10.6
//
// Key difference from manual runs:
//   Sarek BWA-MEM uses -k 19 -B 4 -O 6 -E 1 (its internal defaults),
//   whereas our manual runs used  -k 21 -B 6 -O 5,5 -E 3,3
//   This intentional difference was kept to compare automated vs manual configs.
// =============================================================================

params {

    // ── Input / Output ────────────────────────────────────────────────────────
    input           = "/media/sequentia/sdb1/visitor3/sarek/samplesheets/samplesheet_giab_all.csv"
    outdir          = "/media/sequentia/sdb1/visitor3/process/sarek/deepvariant"

    // ── Reference genome ─────────────────────────────────────────────────────
    // GRCh38 unmasked — same reference used in all manual runs
    genome          = null
    fasta           = "/media/sequentia/sdb1/visitor3/reference/Homo_sapiens.GRCh38.dna.toplevel.fa"
    fasta_fai       = "/media/sequentia/sdb1/visitor3/reference/Homo_sapiens.GRCh38.dna.toplevel.fa.fai"
    bwa             = "/media/sequentia/sdb1/visitor3/reference/bwa_index/"

    // ── Known variant sites for BQSR ─────────────────────────────────────────
    // Same databases used in manual BQSR step
    dbsnp           = "/media/sequentia/sdb1/visitor3/databases/dbsnp_152.hg38.vcf.gz"
    dbsnp_tbi       = "/media/sequentia/sdb1/visitor3/databases/dbsnp_152.hg38.vcf.gz.tbi"
    known_indels    = "/media/sequentia/sdb1/visitor3/databases/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    known_indels_tbi = "/media/sequentia/sdb1/visitor3/databases/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi"

    // ── Analysis scope ────────────────────────────────────────────────────────
    // Chromosome 22 only — consistent with manual benchmarking runs
    intervals       = "chr22"

    // ── Pipeline steps ────────────────────────────────────────────────────────
    // Start from trimmed reads (preprocessing already done with fastp manually)
    // Skip Sarek's built-in trimming — use pre-trimmed FASTQ from samplesheet
    trim_fastq      = false

    // ── Variant caller ────────────────────────────────────────────────────────
    tools           = "deepvariant"

    // ── Analysis type ─────────────────────────────────────────────────────────
    // Germline variant calling (status = 0 in samplesheet)
    // No tumor/normal pairs in this study
    analysis_type   = "germline"

    // ── Container ─────────────────────────────────────────────────────────────
    // Sarek manages all software versions via Docker/Singularity automatically
    // No manual environment activation needed

    // ── Compute ───────────────────────────────────────────────────────────────
    max_cpus        = 30
    max_memory      = "120.GB"
    max_time        = "72.h"

    // ── MultiQC ───────────────────────────────────────────────────────────────
    multiqc_config  = null
}

// ── Executor ─────────────────────────────────────────────────────────────────
// Local execution on the Sequentia student server
process {
    executor = "local"

    // DeepVariant benefits from GPU but CPU mode is used here
    withName: "DEEPVARIANT" {
        cpus   = 30
        memory = "60.GB"
    }

    withName: "BWAMEM1_MEM" {
        cpus   = 30
        memory = "60.GB"
    }

    withName: "GATK4_MARKDUPLICATES" {
        cpus   = 8
        memory = "32.GB"
    }

    withName: "GATK4_BASERECALIBRATOR" {
        cpus   = 8
        memory = "16.GB"
    }
}

// ── Docker ────────────────────────────────────────────────────────────────────
docker {
    enabled    = true
    runOptions = "-u \$(id -u):\$(id -g)"
}

// ── Singularity (alternative to Docker) ──────────────────────────────────────
// singularity {
//     enabled    = true
//     autoMounts = true
// }
